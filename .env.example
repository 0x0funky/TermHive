# Termhive voice — API keys for STT/TTS providers.
# Copy this file to `.env` and fill in the keys you want to use.
# The settings page lets you pick which provider/model is active.

# OpenAI — used for gpt-4o-transcribe (STT) and gpt-4o-mini-tts (TTS).
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — used for gemini-2.5/3.1 STT (multimodal audio) and TTS.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
